layout {

    focus-ring {
        active-color   "#ffb2bc"
        inactive-color "#1a1112"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb2bc"
        inactive-color "#1a1112"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb2bc"
        inactive-color "#72333e"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb2bc80"
    }
}
